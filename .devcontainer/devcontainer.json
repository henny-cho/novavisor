// NovaVisor DevContainer spec. JSONC — comments allowed.
// Schema: https://containers.dev/implementors/json_reference/
{
  "name": "NovaVisor DevContainer",
  "build": {
    "dockerfile": "Dockerfile",
    // Repo root as context so the Dockerfile can COPY scripts/versions.sh.
    "context": ".."
  },
  "remoteUser": "vscode",
  "customizations": {
    "vscode": {
      "settings": {
        "editor.formatOnSave": true,
        "C_Cpp.default.compilerPath": "/opt/toolchain/current/bin/aarch64-none-elf-g++",
        "C_Cpp.default.cStandard": "c17",
        "C_Cpp.default.cppStandard": "c++23",
        "C_Cpp.default.intelliSenseMode": "linux-gcc-arm64",
        "C_Cpp.formatting": "clangFormat",
        "C_Cpp.codeAnalysis.runAutomatically": true,
        "C_Cpp.codeAnalysis.clangTidy.enabled": true
      },
      "extensions": [
        "ms-vscode.cpptools-extension-pack",
        "ms-vscode.cmake-tools",
        "twxs.cmake"
      ]
    }
  },
  "postCreateCommand": "pre-commit install && aarch64-none-elf-gcc --version"
}
