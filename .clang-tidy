---
# NovaVisor Clang-Tidy Configuration
# Enforces strictly embedded zero-cost principles by limiting bad OOP structures.
Checks: >-
    -*,
    cppcoreguidelines-*,
    modernize-*,
    performance-*,
    bugprone-*,
    -bugprone-reserved-identifier,
    -bugprone-easily-swappable-parameters,
    -clang-diagnostic-error,
    -cppcoreguidelines-pro-bounds-pointer-arithmetic,
    -cppcoreguidelines-pro-bounds-constant-array-index,
    -cppcoreguidelines-pro-type-reinterpret-cast,
    -cppcoreguidelines-avoid-non-const-global-variables,
    -cppcoreguidelines-missing-std-forward,
    -cppcoreguidelines-owning-memory,
    -cppcoreguidelines-no-malloc,
    -performance-no-int-to-ptr,
    -readability-identifier-length
# Diagnostics only for NovaVisor's own headers — third-party (external/cache,
# toolchain sysroot) is out of scope and would drown real findings.
# NOTE: clang-tidy 19+ ignores HeaderFilterRegex from this file; task.sh lint
# passes the same regex via -header-filter. Keep the two in sync.
WarningsAsErrors: '*'
HeaderFilterRegex: '/(components|hal|nova|projects)/'

# Options restricting exception throwing because of -fno-exceptions context.
CheckOptions:
  - key:             cert-err58-cpp.ExceptionsAreAllowed
    value:           '0'
