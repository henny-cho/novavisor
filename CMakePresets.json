{
  "version": 3,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja"
    },
    {
      "name": "aarch64-base",
      "hidden": true,
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchain-aarch64.cmake",
        "NOVA_ARCH": "aarch64",
        "NOVA_BOARD": "qemu_virt",
        "NOVA_PROJECT": "qemu_virt_arm64"
      }
    },
    {
      "name": "aarch64-debug",
      "displayName": "AArch64 Debug",
      "description": "Debug build for AArch64 bare-metal",
      "inherits": "aarch64-base",
      "binaryDir": "${sourceDir}/build/aarch64-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "aarch64-release",
      "displayName": "AArch64 Release",
      "description": "Release build for AArch64 bare-metal",
      "inherits": "aarch64-base",
      "binaryDir": "${sourceDir}/build/aarch64-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "host-debug",
      "displayName": "Host Debug",
      "description": "Debug build for host (x86_64) GTest suite",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/host-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "aarch64-debug",
      "configurePreset": "aarch64-debug"
    },
    {
      "name": "aarch64-release",
      "configurePreset": "aarch64-release"
    },
    {
      "name": "host-debug",
      "configurePreset": "host-debug"
    }
  ],
  "testPresets": [
    {
      "name": "host-debug",
      "configurePreset": "host-debug",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
