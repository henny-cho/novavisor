{
  "version": 3,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build"
    },
    {
      "name": "aarch64-base",
      "hidden": true,
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchain-aarch64.cmake"
      }
    },
    {
      "name": "aarch64-debug",
      "displayName": "AArch64 Debug",
      "description": "Debug build for AArch64 bare-metal",
      "inherits": "aarch64-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ENABLE_CLANG_TIDY": "OFF"
      }
    },
    {
      "name": "aarch64-release",
      "displayName": "AArch64 Release",
      "description": "Release build for AArch64 bare-metal",
      "inherits": "aarch64-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ENABLE_CLANG_TIDY": "OFF"
      }
    },
    {
      "name": "aarch64-lint",
      "displayName": "AArch64 Lint",
      "description": "Lint build for AArch64 (ENABLE_CLANG_TIDY=ON)",
      "inherits": "aarch64-debug",
      "cacheVariables": {
        "ENABLE_CLANG_TIDY": "ON"
      }
    },
    {
      "name": "host-debug",
      "displayName": "Host Debug",
      "description": "Debug build for host (x86_64) GTest suite",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/host",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "aarch64-debug",
      "configurePreset": "aarch64-debug"
    },
    {
      "name": "aarch64-release",
      "configurePreset": "aarch64-release"
    },
    {
      "name": "aarch64-lint",
      "configurePreset": "aarch64-lint"
    },
    {
      "name": "host-debug",
      "configurePreset": "host-debug"
    }
  ],
  "testPresets": [
    {
      "name": "host-debug",
      "configurePreset": "host-debug",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
